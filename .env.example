# smolvm environment configuration
# Copy to .env and fill in your values

# Server URL (default: http://127.0.0.1:9090)
# SMOLVM_URL=http://127.0.0.1:9090

# Bearer token for server auth (if enabled)
# SMOLVM_API_TOKEN=

# Claude Code auth — two options:
#
# Option 1 (recommended): Subscription mode via OAuth
#   Run: smolctl auth login
#   This opens a browser, authenticates via Claude.ai, and saves tokens here automatically.
#   Tokens auto-refresh. No API key needed — uses your Claude subscription.
#
# Option 2: API key
#   ANTHROPIC_API_KEY=sk-ant-...
#
# OAuth tokens (set automatically by `smolctl auth login`):
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# CLAUDE_CODE_OAUTH_REFRESH_TOKEN=...
# CLAUDE_CODE_OAUTH_EXPIRES_AT=...
